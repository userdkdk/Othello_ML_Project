#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

changed_files="$(git diff --cached --name-only)"
if [[ -z "$changed_files" ]]; then
  exit 0
fi

if ! printf '%s\n' "$changed_files" | grep -Eq '^(src/|tests/|docs/|specs/|tasks/|agents/|meta/|scripts/build_meta_index\.py|scripts/check_meta_index\.py|Makefile|prompts/)'; then
  exit 0
fi

echo "pre-commit: running make meta-check"
make meta-check
